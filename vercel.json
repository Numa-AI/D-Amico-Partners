{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/area-di-attivita/:path*", "destination": "/#servizi", "permanent": true },
    { "source": "/aree-di-attivita/:path*", "destination": "/#servizi", "permanent": true },
    { "source": "/servizi", "destination": "/#servizi", "permanent": true },
    { "source": "/advisory", "destination": "/#servizi", "permanent": true },
    { "source": "/chi-siamo", "destination": "/#chi-siamo", "permanent": true },
    { "source": "/profilo-societario", "destination": "/#chi-siamo", "permanent": true },
    { "source": "/contatti", "destination": "/#contatti", "permanent": true },
    { "source": "/dove-siamo", "destination": "/#contatti", "permanent": true },
    { "source": "/news/:path*", "destination": "/", "permanent": false }
  ],
  "headers": [
    {
      "source": "/(.*)\\.(css|js|mp4|jpg|jpeg|png|avif|webp|svg|woff2)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
