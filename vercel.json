{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/area-di-attivita/:path*", "destination": "/servizi", "permanent": true },
    { "source": "/aree-di-attivita/:path*", "destination": "/servizi", "permanent": true },
    { "source": "/profilo-societario", "destination": "/chi-siamo", "permanent": true },
    { "source": "/news/:path*", "destination": "/", "permanent": false }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
